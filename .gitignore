# === Secrets & configuration locale (JAMAIS versionnés) ===
config/config.json
config/*.local.json
.env
.env.*
*.key
*.pem
*secret*
*credential*

# === Données : tout ignorer sauf le marqueur de dossier ===
data/*
!data/.gitkeep

# === Logs : tout ignorer sauf le marqueur de dossier ===
logs/*
